{
  "endpoints": {
    "baseUrl": "http://localhost:3000/api/dashboard/trainee",
    "authentication": {
      "header": "Authorization: Bearer <access_token>",
      "role": "TRAINEE"
    }
  },
  "examples": {
    "1_main_dashboard": {
      "endpoint": "GET /api/dashboard/trainee",
      "description": "Main dashboard summary data",
      "request": {
        "method": "GET",
        "url": "/api/dashboard/trainee",
        "headers": {
          "Authorization": "Bearer <access_token>"
        }
      },
      "response": {
        "status": 200,
        "messageEn": "Trainee dashboard data retrieved successfully",
        "messageAr": "تم استرجاع بيانات لوحة تحكم المتدرب بنجاح",
        "data": {
          "currentWeight": 75.5,
          "weightChange30Days": -2.3,
          "activePlan": "Summer Weight Loss Plan",
          "completionPercentage": 65,
          "lastMeasurementDate": "2026-02-08T10:30:00.000Z"
        }
      },
      "response_null_example": {
        "status": 200,
        "messageEn": "Trainee dashboard data retrieved successfully",
        "messageAr": "تم استرجاع بيانات لوحة تحكم المتدرب بنجاح",
        "data": {
          "currentWeight": null,
          "weightChange30Days": null,
          "activePlan": null,
          "completionPercentage": null,
          "lastMeasurementDate": null
        }
      }
    },
    "2_overview": {
      "endpoint": "GET /api/dashboard/trainee/overview",
      "description": "Personal overview statistics",
      "request": {
        "method": "GET",
        "url": "/api/dashboard/trainee/overview",
        "headers": {
          "Authorization": "Bearer <access_token>"
        }
      },
      "response": {
        "status": 200,
        "messageEn": "Trainee overview retrieved successfully",
        "messageAr": "تم استرجاع نظرة عامة للمتدرب بنجاح",
        "data": {
          "currentWeight": 75.5,
          "weightChange7Days": -0.5,
          "weightChange30Days": -2.3,
          "activePlanName": "Summer Weight Loss Plan",
          "planCompletion": 65,
          "daysActiveThisWeek": 5
        }
      },
      "response_partial_data": {
        "status": 200,
        "messageEn": "Trainee overview retrieved successfully",
        "messageAr": "تم استرجاع نظرة عامة للمتدرب بنجاح",
        "data": {
          "currentWeight": 80.0,
          "weightChange7Days": null,
          "weightChange30Days": null,
          "activePlanName": null,
          "planCompletion": 0,
          "daysActiveThisWeek": 2
        }
      }
    },
