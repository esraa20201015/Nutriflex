    "4_today": {
      "endpoint": "GET /api/dashboard/trainee/today",
      "description": "Today's focus (workout & meals)",
      "request": {
        "method": "GET",
        "url": "/api/dashboard/trainee/today",
        "headers": {
          "Authorization": "Bearer <access_token>"
        }
      },
      "response": {
        "status": 200,
        "messageEn": "Today focus data retrieved successfully",
        "messageAr": "تم استرجاع بيانات تركيز اليوم بنجاح",
        "data": {
          "todayWorkout": "Summer Weight Loss Plan",
          "todayMeals": 4,
          "completedMeals": 2,
          "completedWorkout": false
        }
      },
      "response_no_plan": {
        "status": 200,
        "messageEn": "Today focus data retrieved successfully",
        "messageAr": "تم استرجاع بيانات تركيز اليوم بنجاح",
        "data": {
          "todayWorkout": null,
          "todayMeals": 4,
          "completedMeals": 2,
          "completedWorkout": false
        }
      }
    },
    "5_status": {
      "endpoint": "GET /api/dashboard/trainee/status",
      "description": "Motivation & status (streak, check-in, coach)",
      "request": {
        "method": "GET",
        "url": "/api/dashboard/trainee/status",
        "headers": {
          "Authorization": "Bearer <access_token>"
        }
      },
      "response": {
        "status": 200,
        "messageEn": "Trainee status data retrieved successfully",
        "messageAr": "تم استرجاع بيانات حالة المتدرب بنجاح",
        "data": {
          "streakDays": 12,
          "lastCheckIn": "2026-02-08",
          "coachName": "Your Coach"
        }
      },
      "response_no_activity": {
        "status": 200,
        "messageEn": "Trainee status data retrieved successfully",
        "messageAr": "تم استرجاع بيانات حالة المتدرب بنجاح",
        "data": {
          "streakDays": 0,
          "lastCheckIn": null,
          "coachName": "Your Coach"
        }
      }
    }
  },
  "error_examples": {
    "401_unauthorized": {
      "statusCode": 401,
      "message": "Unauthorized"
    },
    "403_forbidden": {
      "messageEn": "User not authenticated",
      "messageAr": "المستخدم غير مصادق عليه"
    },
    "500_internal_error": {
      "statusCode": 500,
      "message": "Internal server error"
    }
  },
  "typescript_interfaces": {
    "comment": "TypeScript interfaces for frontend implementation",
    "DashboardResponse": {
      "status": "number",
      "messageEn": "string",
      "messageAr": "string",
      "data": {
        "currentWeight": "number | null",
        "weightChange30Days": "number | null",
        "activePlan": "string | null",
        "completionPercentage": "number | null",
        "lastMeasurementDate": "string | null"
      }
    },
    "OverviewResponse": {
      "status": "number",
      "messageEn": "string",
      "messageAr": "string",
      "data": {
        "currentWeight": "number | null",
        "weightChange7Days": "number | null",
        "weightChange30Days": "number | null",
        "activePlanName": "string | null",
        "planCompletion": "number",
        "daysActiveThisWeek": "number"
      }
    },
    "ProgressResponse": {
      "status": "number",
      "messageEn": "string",
      "messageAr": "string",
      "data": {
        "weightHistory": "Array<{ date: string; value: number }>",
        "bodyMeasurements": "Array<{ date: string; waist: number | null; chest: number | null }>"
      }
    },
    "TodayResponse": {
      "status": "number",
      "messageEn": "string",
      "messageAr": "string",
      "data": {
        "todayWorkout": "string | null",
        "todayMeals": "number",
        "completedMeals": "number",
        "completedWorkout": "boolean"
      }
    },
    "StatusResponse": {
      "status": "number",
      "messageEn": "string",
      "messageAr": "string",
      "data": {
        "streakDays": "number",
        "lastCheckIn": "string | null",
        "coachName": "string"
      }
    }
  }
}
