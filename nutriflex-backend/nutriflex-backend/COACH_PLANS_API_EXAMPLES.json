{
  "endpoints": {
    "baseUrl": "http://localhost:3000/api",
    "nutritionPlanBase": "/api/nutrition-plan",
    "mealBase": "/api/meal",
    "authentication": {
      "header": "Authorization: Bearer <access_token>",
      "role": "COACH or ADMIN"
    },
    "note": "Coaches must filter plans by coach_id (from JWT token) to see only their own plans."
  },
  "examples": {
    "1_get_all_plans": {
      "endpoint": "GET /api/nutrition-plan",
      "description": "Get all nutrition plans (filtered by coach_id)",
      "request": {
        "method": "GET",
        "url": "/api/nutrition-plan",
        "headers": {
          "Authorization": "Bearer <access_token>"
        },
        "queryParams": {
          "coach_id": "coach-uuid-from-token",
          "status": "active",
          "skip": 0,
          "take": 10
        }
      },
      "response": {
        "status": 200,
        "messageEn": "Nutrition plans retrieved successfully",
        "messageAr": "تم استرجاع خطط التغذية بنجاح",
