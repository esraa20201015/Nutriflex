    "2_create_plan": {
      "endpoint": "POST /api/nutrition-plan",
      "description": "Create a new nutrition plan",
      "request": {
        "method": "POST",
        "url": "/api/nutrition-plan",
        "headers": {
          "Authorization": "Bearer <access_token>",
          "Content-Type": "application/json"
        },
        "body": {
          "coach_id": "coach-uuid-from-token",
          "trainee_id": "trainee-uuid",
          "title": "High Protein Diet Plan",
          "description": "A high protein nutrition plan for muscle building",
          "daily_calories": 2500,
          "start_date": "2026-02-10T00:00:00.000Z",
          "end_date": "2026-12-31T00:00:00.000Z",
          "status": "draft"
        }
      },
      "response": {
        "status": 201,
        "messageEn": "Nutrition plan created successfully",
        "messageAr": "تم إنشاء خطة التغذية بنجاح",
