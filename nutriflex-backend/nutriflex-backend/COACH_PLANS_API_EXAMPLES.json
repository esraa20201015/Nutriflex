  "workflow_example": {
    "description": "Typical workflow for creating a plan with meals",
    "steps": [
      {
        "step": 1,
        "action": "Create nutrition plan",
        "endpoint": "POST /api/nutrition-plan",
        "body": {
          "coach_id": "coach-uuid",
          "trainee_id": "trainee-uuid",
          "title": "New Plan",
          "start_date": "2026-02-10T00:00:00.000Z",
          "status": "draft"
        },
        "response_contains": "plan.id"
      },
      {
        "step": 2,
        "action": "Create meals for the plan",
        "endpoint": "POST /api/meal",
        "body": {
          "nutrition_plan_id": "<plan.id from step 1>",
          "name": "Breakfast Meal",
          "meal_type": "breakfast",
          "calories": 350
        },
        "repeat": "For each meal (breakfast, lunch, dinner, snack)"
      },
      {
        "step": 3,
        "action": "Activate the plan",
        "endpoint": "PUT /api/nutrition-plan/:id/toggle-status",
        "note": "Changes status from draft to active"
      }
    ]
  }
}
