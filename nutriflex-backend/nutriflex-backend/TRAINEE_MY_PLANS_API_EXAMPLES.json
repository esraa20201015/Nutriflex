  "typescript_interfaces": {
    "comment": "TypeScript interfaces for frontend implementation",
    "NutritionPlan": {
      "id": "string",
      "title": "string",
      "description": "string | null",
      "daily_calories": "number | null",
      "start_date": "string",
      "end_date": "string | null",
      "status": "'draft' | 'active' | 'archived'",
      "coach": "{ id: string; fullName: string; email: string }",
      "completionStatus": "{ completion_percentage: number; status: 'not_started' | 'in_progress' | 'completed'; last_updated: string | null }",
      "created_date": "string",
      "updated_date": "string"
    },
    "Meal": {
      "id": "string",
      "name": "string",
      "meal_type": "'breakfast' | 'lunch' | 'dinner' | 'snack'",
      "calories": "number | null",
      "protein": "number | null",
      "carbs": "number | null",
      "fats": "number | null",
      "instructions": "string | null",
      "order_index": "number"
    },
    "PlanDetails": "NutritionPlan & { meals: Meal[] }",
    "PlanStatus": {
      "planId": "string",
      "planTitle": "string",
      "completion_percentage": "number",
      "status": "'not_started' | 'in_progress' | 'completed'",
      "last_updated": "string | null",
      "daysRemaining": "number",
      "daysElapsed": "number",
      "totalDays": "number"
    },
    "PlansListResponse": {
      "status": "number",
      "messageEn": "string",
      "messageAr": "string",
      "data": "NutritionPlan[]",
      "meta": "{ total: number; count: number; skip: number; take: number }"
    },
    "PlanDetailsResponse": {
      "status": "number",
      "messageEn": "string",
      "messageAr": "string",
      "data": "PlanDetails"
    },
    "MealsResponse": {
      "status": "number",
      "messageEn": "string",
      "messageAr": "string",
      "data": "{ planId: string; planTitle: string; meals: Meal[]; groupedByType: { breakfast: Meal[]; lunch: Meal[]; dinner: Meal[]; snack: Meal[] } }"
    },
    "PlanStatusResponse": {
      "status": "number",
      "messageEn": "string",
      "messageAr": "string",
      "data": "PlanStatus"
    }
